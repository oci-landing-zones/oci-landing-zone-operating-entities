{
    "oke_workers_configuration": {
        "default_compartment_id"                : "CMP-LZ-PROD-OKE-KEY",

        "node_pools": {
            "NDP-FRA-LZ-PROD-PLATFORM-OKE-1-KEY": {
                "name"                          : "ndp-fra-lz-prod-platform-oke-1",
                "cluster_id"                    : "CLR-FRA-LZ-PROD-OKE-KEY",
                "enable_cycling"                : false,
                "size"                          : 1,

                "cloud_init": [
                    {
                        "content"               : "runcmd:\n  - sudo /usr/libexec/oci-growfs -y\n",
                        "content_type"          : "text/cloud-config"
                    }
                ],

                "freeform_tags": {
                    "cluster"                   : "clr-fra-lz-prod-oke"
                },

                "networking": {
                    "pods_nsg_ids"              : ["NSG-FRA-LZ-PROD-PLATFORM-OKE-PODS-KEY"],
                    "pods_subnet_id"            : "SN-FRA-LZ-PROD-PLATFORM-OKE-PODS-KEY",
                    "workers_nsg_ids"           : ["NSG-FRA-LZ-PROD-PLATFORM-OKE-WORKERS-KEY"],
                    "workers_subnet_id"         : "SN-FRA-LZ-PROD-PLATFORM-OKE-WORKERS-KEY"
                },

                "node_config_details": {
                    "image"                     : "8.10",
                    "node_shape"                : "VM.Standard.E5.Flex",

                    "flex_shape_settings": {
                        "memory"                : 8,
                        "ocpus"                 : 1
                    }
                }
            }
        }
    }
}
