#!/bin/bash
set -eou pipefail

# Resolve gen directory relative to the repo root, not the hook location
REPO_ROOT=$(git rev-parse --show-toplevel)
GEN_DIR="$REPO_ROOT/gen"

echo "Generating templates 📄"
./gen/generate.sh

# Stage only the generated output files (those with a .jsonnet template)
while IFS= read -r -d '' jsonnet_file; do
  rel_path="${jsonnet_file#$GEN_DIR/}"
  json_file="${rel_path%.jsonnet}.json"
  if [ -f "$json_file" ]; then
    git add "$json_file"
  fi
done < <(find "$GEN_DIR" -type f -name "*.jsonnet" -print0)

exit 0
