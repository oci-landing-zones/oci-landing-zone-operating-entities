{
    "instances_configuration": {
        "default_compartment_id": "CMP-LZ-MONITORING-KEY",
        "default_ssh_public_key_path": "ssh-rsa AAAAB3NzaC1......RgQ== user@example.com",
        "instances": {
            "VM-FRA-LZ-SHARED-MON-AGENT-KEY": {
                "name": "vm-fra-lz-shared-mon-agent",
                "shape": "VM.Standard.E4.Flex",
                "boot_volume": {
                    "preserve_on_instance_deletion": false,
                    "size": 60
                },
                "cloud_agent": {
                    "disable_management": false,
                    "disable_monitoring": false,
                    "plugins": [
                        {
                            "name": "Management Agent",
                            "enabled": true
                        },
                        {
                            "name": "Custom Logs Monitoring",
                            "enabled": true
                        },
                        {
                            "name": "Compute Instance Monitoring",
                            "enabled": true
                        },
                        {
                            "name": "Vulnerability Scanning",
                            "enabled": true
                        },
                        {
                            "name": "OS Management Service Agent",
                            "enabled": true
                        }
                    ]
                },
                "encryption": {
                    "encrypt_in_transit_on_instance_create": null,
                    "encrypt_in_transit_on_instance_update": null
                },
                "flex_shape_settings": {
                    "memory_in_gbs": 16,
                    "ocpus": 2
                },
                "networking": {
                    "assign_public_ip": false,
                    "hostname": "vm-fra-lz-shared-mon-agent",
                    "subnet_id": "SN-FRA-LZ-HUB-MON-KEY"
                },
                "placement": {
                    "availability_domain": 1,
                    "fault_domain": 1
                },
                "platform_image": {
                    "name": "Oracle-Linux-Cloud-Developer-8.10-2025.01.31-0"
                }
            }
        }
    }
}
