{
    "compartments_configuration": {
        "enable_delete": "true",
        "default_parent_id":"CMP-LANDINGZONE-KEY",
        "compartments": {
            "CMP-LZ-PROD-MONITORING-KEY": {
                "parent_id":"CMP-LZ-PROD-PLATFORM-KEY",
                "name": "cmp-lz-prod-monitoring",
                "description": "Observability Production Compartment"
            },
            "CMP-LZ-PREPROD-MONITORING-KEY": {
                "parent_id":"CMP-LZ-PREPROD-PLATFORM-KEY",
                "name": "cmp-lz-preprod-monitoring",
                "description": "Observability PreProduction Compartment"
            }
        }
    },
    "identity_domain_groups_configuration": {
        "default_identity_domain_id": "COMMON-DOMAIN",
        "ignore_external_membership_updates": true,
        "groups": {
               "GRP-MON-ADMINS": {
                "name": "grp-lz-global-mon-admins",
                "description": "Tenancy global Observability administrator group."
            },
            "GRP-PROD-MON-ADMINS": {
                "name": "grp-lz-prod-mon-admins",
                "description": "Production Observability admin group."
            },
            "GRP-PREPROD-MON-ADMINS": {
                "name": "grp-lz-preprod-mon-admins",
                "description": "Preprod Observability admin group."
            }
        }
    },
    "dynamic_groups_configuration": {
        "default_defined_tags": null,
        "default_freeform_tags": null,
        "dynamic_groups": {
          "DG-LZ-MON": {
            "name": "dg-lz-mon-dynamic-group",
            "description": "dynamic group for security functions execution, required for Logging Analytics",
            "matching_rule": "ALL {resource.type='managementagent'}"
          }
        }
      }
}
